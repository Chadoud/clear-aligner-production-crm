# Server
PORT=4000
NODE_ENV=development

# Trust reverse-proxy hops for req.ip / rate limits (X-Forwarded-For).
# Production default is 1 when NODE_ENV=production. Dev default is off.
# Only enable when Node is bound to localhost behind nginx (not public :4000).
# TRUST_PROXY=1

# Bind address. Production default 127.0.0.1 (nginx → local API only).
# LISTEN_HOST=127.0.0.1

# MySQL (for local tunnel: bash scripts/mysql-tunnel.sh with SSH_* / REMOTE_HOST set)
SOURCE_DB_URL=mysql://DB_USER:DB_PASSWORD@127.0.0.1:3307/DB_NAME

# Frontend origin (CORS)
CORS_ORIGIN=http://localhost:3000

# Public URL of the CRM (email buttons: case sheet, Doctors billing, login, password reset)
# APP_BASE_URL=https://crm.example.com

# Deployment-specific brand / lab profile (set in private ops; leave unset here)
# DIRECT_CABINET_ID=
# DUAL_LAB_PROFILE_EMAIL=

# Auth (required in production)
JWT_SECRET=change-me-generate-a-long-random-string
# Optional: X-API-Key header for server-to-server
# API_KEY=your-api-key

# Scheduled jobs: POST /api/v1/cron/doctor-billing-reminders with header X-Cron-Secret
# CRON_SECRET=generate-a-long-random-string

# Logging
LOG_LEVEL=info

# SMTP (password reset, invoice emails). If SMTP_PASSWORD is unset, transactional email is skipped.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
# SMTP_PASSWORD=
# FROM_EMAIL=noreply@example.com
# FROM_NAME=Clear Aligner Production CRM
# LAB_NOTIFICATION_EMAIL=lab@example.com

# ORG_CONTACT_EMAIL=info@example.com
# ORG_CONTACT_PHONE=+41 00 000 00 00
# ORG_CONTACT_ADDRESS=Your Org|Street|Postal code City|Country
# ORG_CONTACT_WEBSITE=https://www.example.com

# Local file storage (served by this API at /data/uploads and /api/v1/media/profile)
# UPLOADS_DIR=data/uploads
# PROFILE_DIR=data/profile

# Optional mobile API (profile sync / Socket.IO bridge)
# MOBILE_API_BASE_URL=https://api.example.com
# MOBILE_JWT_SECRET=
# MOBILE_INTERNAL_API_KEY=
