# Frontend (Vite) — copy to `.env`. Never commit real `.env` files.
# Backend secrets and MySQL: see `backend/.env.example`.

VITE_APP_NAME=Aligner_Production_CRM
# VITE_LOG_LEVEL=info
# VITE_STORAGE_NAMESPACE=aligner-crm
# VITE_FEATURE_FLAGS=invoiceGenerated,pdfDownload
# VITE_ENABLE_DEVTOOLS=true

# Load patients, cabinets, and services from the Fastify API (required for the template).
VITE_USE_API=true

# Case documents use same-origin `/data/uploads/...` (Vite proxies to the local API).
# Optional absolute CRM origin for production builds (no trailing slash):
# VITE_DOCS_BASE_URL=https://crm.example.com

# Override the /data proxy target in development (defaults to http://localhost:4000):
# VITE_DOCS_PROXY_TARGET=http://localhost:4000

# Optional mobile API host for profile images stored under /uploads/profile/...
# VITE_API_FALLBACK_URL=https://api.example.com

# Deployment-specific (leave unset for local demo):
# VITE_DIRECT_CABINET_ID=
# VITE_DUAL_LAB_PROFILE_EMAIL=
